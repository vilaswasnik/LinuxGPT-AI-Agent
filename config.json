{
  "agent": {
    "name": "Linux Command Agent",
    "version": "1.0.0",
    "description": "Natural Language to Linux Command System"
  },
  "llm": {
    "provider": "openai",
    "model": "gpt-4",
    "temperature": 0.3,
    "max_tokens": 500
  },
  "security": {
    "enable_dangerous_command_check": true,
    "command_timeout_seconds": 30,
    "dangerous_patterns": [
      "rm -rf /",
      "mkfs",
      ":(){ :|:& };:",
      "dd if=/dev/random",
      "chmod -R 777 /"
    ]
  },
  "database": {
    "path": "linux_commands_db.json"
  }
}
